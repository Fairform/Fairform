# Create the file with all required environment variables
cat > .env.local.example << 'EOL'
# Fairform Environment Variables
# ==================================
# Production secrets - DO NOT COMMIT

# API Keys
OPENAI_API_KEY=sk-mock_openai_api_key_123

# Authentication
NEXT_PUBLIC_GOOGLE_CLIENT_ID=google_client_id_mock_123.apps.googleusercontent.com
NEXT_PUBLIC_GITHUB_CLIENT_ID=github_client_id_mock_123

# Security
CRON_SECRET=mock_cron_secret_123

# Deployment
NEXT_PUBLIC_VERCEL_ENV=development

# Scraper configuration
SCRAPER_TIMEOUT=10000
SCRAPER_RATE_LIMIT=2000
EOL
